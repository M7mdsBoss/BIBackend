generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String    @id
  name              String
  campany           String?
  industry          String?
  campanySize       String?   @db.VarChar(10)
  campanyRole       String?
  website           String?
  phone             String?
  email             String    @unique
  password          String
  generatedToken    String    @unique
  role              String  @default("OWNER")
  createdAt         DateTime  @default(now())
  confirmed         Boolean   @default(false)
  acceptedAuthorize Boolean   @default(false)
  acceptedTerms     Boolean   @default(false)

  // Self-referential: OWNER → members (GUARD, etc.)
  ownerId           String?
  owner             User?           @relation("OrgMembers", fields: [ownerId], references: [id], onDelete: SetNull)
  members           User[]          @relation("OrgMembers")

  // OWNER → Compounds they own
  compounds         Compound[]      @relation("OwnerCompounds")

  // OPERATION/GUARD → Compounds they are assigned to
  assignedCompounds AssignedCompound[]

  // SRS and Visit records linked via generatedToken
  srsRecords        srs[]   @relation("UserSrs")
  visits            Visit[] @relation("UserVisit")
}

// ── Compound & Unit ───────────────────────────────────────────────────────────

model Compound {
  id        String   @id
  name      String
  slug      String   @unique // COMP_{normalized_name}
  createdAt DateTime @default(now())

  ownerId String
  owner   User   @relation("OwnerCompounds", fields: [ownerId], references: [id], onDelete: Cascade)

  units      Unit[]
  assignedMembers AssignedCompound[]
  srsRecords srs[]   @relation("CompoundSrs")
  visits     Visit[] @relation("CompoundVisit")
}

model Unit {
  id        String   @id
  name      String
  slug      String   @unique // UNIT_{normalized_name}
  createdAt DateTime @default(now())

  compoundId String
  compound   Compound @relation(fields: [compoundId], references: [id], onDelete: Cascade)

  srsRecords srs[]   @relation("UnitSrs")
  visits     Visit[] @relation("UnitVisit")
}

// Junction: Member ↔ Compound (many-to-many, scoped to the same Owner)
model AssignedCompound {
  assignedAt DateTime @default(now())

  guardId String
  guard   User   @relation(fields: [guardId], references: [id], onDelete: Cascade)

  compoundId String
  compound   Compound @relation(fields: [compoundId], references: [id], onDelete: Cascade)

  @@id([guardId, compoundId])
}

// ── SubscriptionRequest ───────────────────────────────────────────────────────

model SubscriptionRequest {
  id              String   @id
  name            String
  campany         String?
  industry        String?
  city            String?
  country         String?
  totalBranches   String?
  chatVolume      String?  @db.VarChar(10)
  aiIntegration   String?  @db.VarChar(3)
  campanySize     String?
  website         String?
  phone           String?
  email           String   @unique
  password        String
  generatedToken  String   @unique
  role            String   @default("User") @db.VarChar(10)
  createdAt       DateTime @default(now())
  whatsapp        String?
  confirmed       Boolean  @default(false)
  acceptedAuthorize Boolean @default(false)
  acceptedTerms     Boolean @default(false)
  campanyRole     String
  plan              String
 
}

model Visit {
  id                  String   @id
  residentFullName    String
  residentUnit        String
  residentPhone       String
  visitorFullName     String
  visitorCarType      String
  visitorLicensePlate String
  visitDate           DateTime
  visitTime           String
  pdfUrl              String?
  qrCode              String?
  scanned             Boolean @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime
  isExpired           Boolean  @default(false)
  compound            String?
  compoundRef         Compound? @relation("CompoundVisit", fields: [compound], references: [slug])
  residentUnitRef     Unit?     @relation("UnitVisit", fields: [residentUnit], references: [slug])
  userToken           String?
  userRef             User?     @relation("UserVisit", fields: [userToken], references: [generatedToken])
}

model customers {
  customer_id  Int      @id @default(autoincrement())
  first_name   String   @db.VarChar(100)
  last_name    String   @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  phone_number String?  @db.VarChar(20)
  address      String?
  city         String?  @db.VarChar(100)
  country      String?  @db.VarChar(100)
  postal_code  String?  @db.VarChar(20)
  landbot_id   String?  @unique @db.VarChar(100)
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @db.Timestamptz(6)
}

model dashborad_Insights {
  id        Int       @id @default(autoincrement())
  Instagram String?
  Whatsapp  String?
  Tiktok    String?
  Twitter   String?
  Created   DateTime? @db.Timestamptz(6)
}

model dashborad_data_q_r_ {
  id                  Int       @id @default(autoincrement())
  index_number_       Int?      @map("index_number ")
  tiktok_question_    String?   @map("tiktok_question ")
  tiktok_request_     String?   @map("tiktok_request ")
  instagram_question_ String?   @map("instagram_question ")
  instagram_request_  String?   @map("instagram_request ")
  whatsapp_question_  String?   @map("whatsapp_question ")
  whatsapp_request_   String?   @map("whatsapp_request ")
  twitter_question_   String?   @map("twitter_question ")
  twitter_request_    String?   @map("twitter_request ")
  created_at_         DateTime? @map("created_at ") @db.Timestamptz(6)

  @@map("dashborad_data_q_r ")
}

model n8n_chat_histories {
  id         Int    @id @default(autoincrement())
  session_id String @db.VarChar(255)
  message    Json
}

model payment_events {
  id          BigInt   @id @default(autoincrement())
  payment_id  String   @db.Uuid
  event_type  String
  raw         Json?
  result_code String?
  result_desc String?
  occurred_at DateTime @default(now()) @db.Timestamptz(6)
  payments    payments @relation(fields: [payment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([payment_id], map: "idx_payment_events_payment_id")
}

model payments {
  id                      String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  environment             String           @default("prod")
  order_ref               String
  merchant_transaction_id String?
  checkout_id             String?
  gateway_payment_id      String?
  integrity_sri           String?
  amount                  Decimal          @db.Decimal(12, 2)
  currency                String
  entity_id               String
  return_token            String
  status                  String           @default("pending")
  result_code             String?
  result_desc             String?
  customer_email          String?
  customer_given_name     String?
  customer_surname        String?
  billing_street1         String?
  billing_city            String?
  billing_state           String?
  billing_country         String?
  billing_postcode        String?
  csp_nonce_used          String?
  created_at              DateTime         @default(now()) @db.Timestamptz(6)
  updated_at              DateTime         @default(now()) @db.Timestamptz(6)
  customer_phone          String?
  payment_events          payment_events[]

  @@index([checkout_id], map: "idx_payments_checkout_id")
  @@index([customer_phone], map: "idx_payments_customer_phone")
  @@index([order_ref, environment], map: "idx_payments_order_env")
}

model requests {
  id                       BigInt            @id @default(autoincrement())
  whatsapp_message_id      BigInt
  request_text             String
  assigned_to              String?
  tg_chat_id               BigInt?
  tg_initial_message_id    BigInt?
  tg_assignment_message_id BigInt?
  created_at               DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at               DateTime?         @default(now()) @db.Timestamptz(6)
  updated_by_id            String?
  updated_by               String?
  status                   String?
  room                     String?
  whatsapp_messages        whatsapp_messages @relation(fields: [whatsapp_message_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model template_sent {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(255)
  room_number  String?   @db.VarChar(50)
  phone        String    @db.VarChar(20)
  within24h    String?   @db.VarChar(10)
  outin24h     String?   @db.VarChar(10)
  template_id  Int?
  customer_id  Int?
  opt_in       String?   @db.VarChar(10)
  row_number   Int?
  execution_id String?   @db.VarChar(50)
  node_status  String?   @db.VarChar(20)
  inserted_at  DateTime? @default(now()) @db.Timestamptz(6)
}

model tiktok_messages {
  id                Int       @id @default(autoincrement())
  tiktok_name       String?
  message           String?
  response          String?
  created_date_time DateTime? @db.Timestamp(6)
  client            String?
  message_type      String?
}

model whatsapp_messages {
  Name                  String?
  phone_number          BigInt?
  gpt_content           String?
  message_object        String?
  user_text             String?
  client                String?
  message_type          String?
  timestamp             DateTime?  @db.Timestamp(6)
  id                    BigInt     @id @default(autoincrement())
  guest                 Boolean?
  az_bs                 String?
  wo_category           String?
  wo_priority           String?
  wo_subcategory        String?
  wo_code               String?
  wo_statusmessage      String?
  wo_status_last_update String?
  requests              requests[]
}

model n8n_vectors {
  id        String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  text      String?
  metadata  Json?
  embedding Unsupported("vector")?
}

model n8n_vectors_v2 {
  id        String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  text      String?
  metadata  Json?
  embedding Unsupported("vector")?
}

model srs {
  id               Int       @id @default(autoincrement())
  resname          String?   @db.VarChar(100)
  resphone         String?   @db.VarChar(20)
  resemail         String?   @db.VarChar(100)
  compound         String?   @db.VarChar(100)
  compoundRef      Compound? @relation("CompoundSrs", fields: [compound], references: [slug])
  unit             String?   @db.VarChar(50)
  unitRef          Unit?     @relation("UnitSrs", fields: [unit], references: [slug])
  userToken        String?   @db.VarChar(12)
  userRef          User?     @relation("UserSrs", fields: [userToken], references: [generatedToken])
  propertycode     String?   @db.VarChar(50)
  priority         String?   @db.VarChar(20)
  leasename        String?   @db.VarChar(100)
  leasecode        String?   @db.VarChar(50)
  category         String?   @db.VarChar(100)
  subcategory      String?   @db.VarChar(100)
  breifdescription String?
  timetoenter      DateTime? @db.Time(6)
  datetime         DateTime? @default(now()) @db.Timestamp(6)
  status           String?   @default("Open") @db.VarChar(20)
  yardi_wo_code    String?   @db.VarChar(50)
  closed_at        DateTime? @db.Timestamp(6)
  is_closed        Boolean?  @default(false)
  updated_at       DateTime? @db.Timestamp(6)

  @@index([yardi_wo_code], map: "idx_srs_yardi_wo_code")
}
